<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  admin_users.fxml — Quản lý toàn bộ users.
  Có search, filter theo status, TableView với action buttons.
-->

<VBox spacing="16" styleClass="content-area" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminUsersController">
    <stylesheets>
        <URL value="@global.css" />
    </stylesheets>

    <!-- ── Header ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size:18px;" styleClass="section-title" text="Manage Users" />
            <Label styleClass="section-subtitle" text="View, ban, or remove user accounts from the system." />
        </VBox>
        <Label fx:id="totalLabel" styleClass="section-subtitle" text="0 users total" />
    </HBox>

    <!-- ── Filter + Search bar ────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">

        <Button fx:id="tabAll" onAction="#showAll" styleClass="btn-primary" text="All" textAlignment="CENTER" />
        <Button fx:id="tabActive" onAction="#showActive" styleClass="btn-secondary" text="Active" />
        <Button fx:id="tabBanned" onAction="#showBanned" styleClass="btn-secondary" text="Banned" />
        <Button fx:id="tabAdmin" onAction="#showAdmins" styleClass="btn-secondary" text="Admins" />

        <Region HBox.hgrow="ALWAYS" />

        <!-- Search -->
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding:6 12; -fx-background-radius:8;" styleClass="section-card">
            <Label style="-fx-font-size:13px; -fx-text-fill:#a0aec0;" text="🔍" />
            <TextField fx:id="searchField" onAction="#handleSearch" prefWidth="220" promptText="Search by username or email..." style="-fx-background-color:transparent; -fx-border-width:0;" />
        </HBox>
        <Button onAction="#handleSearch" styleClass="btn-primary" text="Search" />
    </HBox>

    <!-- ── Users Table ────────────────────────────────────── -->
    <VBox spacing="0" styleClass="section-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="usersTable" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80" style="-fx-alignment:CENTER;" text="ID" />
                <TableColumn fx:id="colAvatar" prefWidth="52" style="-fx-alignment:CENTER;" text="" />
                <TableColumn fx:id="colUsername" prefWidth="200" text="USERNAME" />
                <TableColumn fx:id="colEmail" prefWidth="170" text="EMAIL" />
                <TableColumn fx:id="colRole" prefWidth="80" style="-fx-alignment:CENTER;" text="ROLE" />
                <TableColumn fx:id="colStatus" prefWidth="80" style="-fx-alignment:CENTER;" text="STATUS" />
                <TableColumn fx:id="colBids" prefWidth="70" style="-fx-alignment:CENTER;" text="BIDS" />
                <TableColumn fx:id="colActions" prefWidth="200" style="-fx-alignment:CENTER;" text="ACTIONS" />
            </columns>
            <placeholder>
                <Label style="-fx-text-fill:#a0aec0; -fx-font-size:13px;" text="No users found." />
            </placeholder>
        </TableView>
    </VBox>

</VBox>
