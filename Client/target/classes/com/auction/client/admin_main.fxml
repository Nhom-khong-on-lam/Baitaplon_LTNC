<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  admin_main.fxml — App shell dành riêng cho Admin.
  Sidebar tối màu + content pane bên phải.
  Load động bởi AdminMainController.
-->

<HBox fx:id="adminRoot" prefHeight="720" prefWidth="1200" styleClass="main-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminMainController">
    <stylesheets>
        <URL value="@global.css" />
    </stylesheets>

    <!-- ══ SIDEBAR ADMIN ══════════════════════════════════ -->
    <VBox fx:id="sidebar" prefWidth="230" styleClass="sidebar">

        <!-- Logo + Admin badge -->
        <VBox spacing="4" styleClass="sidebar-logo-area">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label styleClass="sidebar-logo" text="AURUM" />
                <Label styleClass="sidebar-logo-dot" text="." />
            </HBox>
            <Label styleClass="sidebar-tagline" text="ADMIN PANEL" />
            <!-- Admin badge -->
            <Label style="-fx-background-color:#1e3a5f; -fx-text-fill:#60a5fa;                           -fx-background-radius:20; -fx-font-size:10px;                           -fx-font-weight:bold; -fx-padding:3 10;                           -fx-max-width:120;" text="⚙  Administrator" />
        </VBox>

        <!-- OVERVIEW section -->
        <Label styleClass="sidebar-section" text="OVERVIEW" />

        <Button fx:id="navDashboard" maxWidth="Infinity" onAction="#navDashboard" styleClass="nav-btn" text="📊  Dashboard" />

        <!-- MANAGEMENT section -->
        <Label styleClass="sidebar-section" text="MANAGEMENT" />

        <Button fx:id="navUsers" maxWidth="Infinity" onAction="#navUsers" styleClass="nav-btn" text="👥  Manage Users" />

        <Button fx:id="navAuctions" maxWidth="Infinity" onAction="#navAuctions" styleClass="nav-btn" text="🔨  Manage Auctions" textAlignment="CENTER" />
        <Button fx:id="navApprovals"
                text="🔔  Kiểm Duyệt"
                onAction="#navApprovals"
                styleClass="sidebar-btn" />

        <!-- Spacer -->
        <Region VBox.vgrow="ALWAYS" />

        <!-- Logout -->
        <Button onAction="#handleLogout" style="-fx-background-color:transparent; -fx-text-fill:#4a3030;                        -fx-font-size:12px; -fx-font-weight:bold;                        -fx-alignment:CENTER_LEFT; -fx-padding:10 20;                        -fx-cursor:hand; -fx-max-width:Infinity;" text="🚪  Sign Out" />

        <!-- Admin user area -->
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-user-area">
            <Label fx:id="sidebarAvatar" styleClass="sidebar-avatar" text="AD" />
            <VBox spacing="1">
                <Label fx:id="sidebarUserName" styleClass="sidebar-user-name" text="Admin" />
                <Label style="-fx-text-fill:#60a5fa;" styleClass="sidebar-user-role" text="Administrator" />
            </VBox>
        </HBox>

    </VBox>

    <!-- ══ RIGHT SIDE — Topbar + Content ══════════════════ -->
    <VBox HBox.hgrow="ALWAYS">

        <!-- Topbar -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
            <VBox spacing="1" HBox.hgrow="ALWAYS">
                <Label fx:id="topbarTitle" styleClass="topbar-page-title" text="Admin Dashboard" />
                <Label fx:id="topbarBread" styleClass="topbar-breadcrumb" text="Admin / Dashboard" />
            </VBox>
            <!-- Search -->
            <TextField fx:id="topbarSearch" onAction="#handleSearch" promptText="Search users, auctions..." styleClass="topbar-search" />
            <!-- Admin badge topbar -->
            <Label style="-fx-background-color:#dbeafe; -fx-text-fill:#1d4ed8;                           -fx-background-radius:20; -fx-font-size:10px;                           -fx-font-weight:bold; -fx-padding:4 12;" text="⚙ ADMIN" />
            <Label fx:id="topbarAvatar" onMouseClicked="#handleAvatarClick" styleClass="topbar-avatar-btn" text="  AD" />
        </HBox>

        <!-- Dynamic content -->
        <StackPane fx:id="contentPane" styleClass="content-area" VBox.vgrow="ALWAYS" />
    </VBox>

</HBox>
