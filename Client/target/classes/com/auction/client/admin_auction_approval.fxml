<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.AdminAuctionApprovalController"
      spacing="0"
      style="-fx-background-color: #f8fafc;">

    <VBox style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="20" right="28" bottom="0" left="28"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label text="🔔" style="-fx-font-size: 26px;"/>
            <VBox spacing="2">
                <Label text="Auction Approvals" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a Haus;"/>
                <Label text="Review and manage new auction rooms submitted by users" style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="pendingBadge" text="0" visible="false"
                   style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 4 10; -fx-background-radius: 12; -fx-font-size: 12px;"/>
        </HBox>

        <HBox spacing="6" style="-fx-margin-top: 15;">
            <padding><Insets top="15" bottom="0"/></padding>
            <Button fx:id="tabPending" text="Pending Approval" onAction="#showPending"
                    styleClass="btn-primary" style="-fx-background-radius: 6 6 0 0; -fx-cursor: hand;"/>
            <Button fx:id="tabApproved" text="Approved (Running)" onAction="#showApproved"
                    styleClass="btn-secondary" style="-fx-background-radius: 6 6 0 0; -fx-cursor: hand;"/>
            <Button fx:id="tabRejected" text="Rejected" onAction="#showRejected"
                    styleClass="btn-secondary" style="-fx-background-radius: 6 6 0 0; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="12" right="28" bottom="12" left="28"/></padding>
        <TextField fx:id="searchField" promptText="🔍 Type keywords and press Enter to search..." prefWidth="320" onAction="#handleSearch"
                   style="-fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-padding: 7 10;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="totalLabel" text="0 auctions" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <padding><Insets top="20" right="28" bottom="20" left="28"/></padding>

        <TableView fx:id="approvalTable" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;" VBox.vgrow="ALWAYS">
            <placeholder>
                <VBox alignment="CENTER" spacing="10">
                    <Label text="📭" style="-fx-font-size: 40px;"/>
                    <Label text="No auctions found here!" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <Label text="Please click the status tabs above to refresh the list." style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;"/>
                </VBox>
            </placeholder>

            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colTitle" text="Item Name" prefWidth="180"/>
                <TableColumn fx:id="colSeller" text="Seller" prefWidth="120"/>
                <TableColumn fx:id="colCategory" text="Category" prefWidth="110" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colStartPrice" text="Starting Price" prefWidth="130" style="-fx-alignment: CENTER_RIGHT;"/>
                <TableColumn fx:id="colDescription" text="Description" prefWidth="220"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colSubmittedAt" text="Submission Time" prefWidth="160" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="180" style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </StackPane>
</VBox>