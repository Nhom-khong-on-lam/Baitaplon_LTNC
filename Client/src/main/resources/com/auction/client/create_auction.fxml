<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import java.net.URL?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.CreateAuctionController"
            fitToWidth="true" styleClass="scroll-pane">
    <stylesheets>
        <URL value="@global.css"/>
    </stylesheets>

    <VBox spacing="20" styleClass="content-area">

        <HBox alignment="CENTER_LEFT">
            <VBox HBox.hgrow="ALWAYS" spacing="3">
                <Label fx:id="pageTitle" text="Create Auction"
                       styleClass="section-title" style="-fx-font-size:18px;"/>
                <Label text="Fill in the details below to list your item for auction."
                       styleClass="section-subtitle"/>
            </VBox>
            <Button text="← Back" styleClass="btn-secondary" onAction="#goBack"/>
        </HBox>

        <HBox spacing="20" alignment="TOP_LEFT">

            <VBox spacing="16" prefWidth="380" minWidth="380">

                <VBox styleClass="section-card" spacing="12">
                    <Label text="PRODUCT IMAGE" styleClass="form-label"/>

                    <VBox fx:id="imagePreviewBox" alignment="CENTER" spacing="12" minHeight="160"
                          style="-fx-border-style: dashed; -fx-border-color: #cbd5e1; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-color: #f8fafc;">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label fx:id="imageHint" text="No file selected (.png, .jpg, .webp)"
                               style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-text-alignment: center;" wrapText="true"/>

                        <Button text="Choose Local File" styleClass="btn-secondary"
                                style="-fx-padding: 6 14; -fx-font-size: 12px;"
                                onAction="#handleImageUpload"/>
                    </VBox>
                    <Label fx:id="msgImage" styleClass="form-error"/>
                </VBox>

                <VBox styleClass="section-card" spacing="14">
                    <Label text="PRICING &amp; BIDDING" styleClass="form-label"/>

                    <VBox spacing="5">
                        <Label text="Starting Price *" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                        <TextField fx:id="fieldStartPrice" promptText="e.g. 1000"/>
                        <Label fx:id="msgPrice" styleClass="form-error"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Bid Increment (Optional)" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                        <TextField fx:id="fieldBidIncrement" promptText="e.g. 50 (Leave blank for auto 5%)"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Reserve Price (Optional)" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                        <TextField fx:id="fieldReservePrice" promptText="Hidden minimum price to win"/>
                    </VBox>
                </VBox>
            </VBox>

            <VBox spacing="16" HBox.hgrow="ALWAYS">

                <VBox styleClass="section-card" spacing="14">
                    <Label text="ITEM DETAILS" styleClass="form-label"/>

                    <VBox spacing="5">
                        <Label text="Auction Title *" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                        <TextField fx:id="fieldTitle" promptText="e.g. iPhone 14 Pro Max 256GB Midnight"/>
                        <Label fx:id="msgTitle" styleClass="form-error"/>
                    </VBox>

                    <HBox spacing="14">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Category *" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                            <ComboBox fx:id="fieldCategory" maxWidth="Infinity" promptText="Select Category"/>
                            <Label fx:id="msgCategory" styleClass="form-error"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Item Condition *" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                            <ComboBox fx:id="fieldCondition" maxWidth="Infinity" promptText="Select Condition"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="5">
                        <Label text="Full Description *" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                        <TextArea fx:id="fieldDesc" prefHeight="115" wrapText="true"
                                  promptText="Describe your item's key features, condition, defects, or shipping terms..."/>
                        <Label fx:id="msgDesc" styleClass="form-error"/>
                    </VBox>
                </VBox>

                <VBox styleClass="section-card" spacing="14">
                    <Label text="AUCTION SCHEDULING" styleClass="form-label"/>

                    <VBox spacing="5">
                        <Label text="Start Time (YYYY-MM-DD HH:mm)" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                        <TextField fx:id="fieldStartTime"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="End Time * (YYYY-MM-DD HH:mm)" style="-fx-font-size:12px; -fx-text-fill:#4a5568;"/>
                        <TextField fx:id="fieldEndTime"/>
                        <Label fx:id="msgTime" styleClass="form-error"/>
                    </VBox>

                    <Label text="QUICK DURATION" styleClass="form-label"/>
                    <HBox spacing="8">
                        <Button text="1 Day"  styleClass="btn-secondary"
                                style="-fx-font-size:11px; -fx-padding:5 10;"
                                onAction="#set1Day"/>
                        <Button text="3 Days" styleClass="btn-secondary"
                                style="-fx-font-size:11px; -fx-padding:5 10;"
                                onAction="#set3Days"/>
                        <Button text="7 Days" styleClass="btn-secondary"
                                style="-fx-font-size:11px; -fx-padding:5 10;"
                                onAction="#set7Days"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>

        <HBox styleClass="section-card" alignment="CENTER_LEFT" spacing="14">
            <Label fx:id="formMsg" styleClass="form-error" HBox.hgrow="ALWAYS"/>
            <Button text="Save as Draft" styleClass="btn-secondary" onAction="#saveDraft"/>
            <Button fx:id="submitBtn" text="Publish Auction →"
                    styleClass="btn-primary" onAction="#handleSubmit"/>
        </HBox>

        <Region minHeight="20"/>
    </VBox>
</ScrollPane>