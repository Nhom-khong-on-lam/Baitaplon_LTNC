<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  create_auction.fxml — Form tạo hoặc chỉnh sửa phiên đấu giá.
-->

<ScrollPane fitToWidth="true" styleClass="scroll-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.CreateAuctionController">
    <stylesheets>
        <URL value="@global.css" />
    </stylesheets>

    <VBox spacing="20" styleClass="content-area">

        <!-- ── Header ─────────────────────────────────────── -->
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label fx:id="pageTitle" style="-fx-font-size:18px;" styleClass="section-title" text="Create Auction" />
                <Label styleClass="section-subtitle" text="Fill in the details below to list your item for auction." />
            </VBox>
            <Button onAction="#goBack" styleClass="btn-secondary" text="← Back" />
        </HBox>

        <HBox alignment="TOP_LEFT" spacing="20">

            <!-- ── Left Column: Main Form ─────────────────── -->
            <VBox spacing="18" styleClass="section-card" HBox.hgrow="ALWAYS">
                <Label styleClass="section-title" text="Auction Details" />

                <!-- Title -->
                <VBox spacing="6">
                    <Label styleClass="form-label" text="AUCTION TITLE *" />
                    <TextField fx:id="fieldTitle" promptText="e.g., Apple iPhone 15 Pro Max 256GB" styleClass="form-input" />
                    <Label fx:id="msgTitle" styleClass="form-error" />
                </VBox>

                <!-- Description -->
                <VBox spacing="6">
                    <Label styleClass="form-label" text="DESCRIPTION *" />
                    <TextArea fx:id="fieldDesc" prefRowCount="4" promptText="Describe the item condition, features, and any important details..." styleClass="form-input" wrapText="true" />
                    <Label fx:id="msgDesc" styleClass="form-error" />
                </VBox>

                <!-- Category + Condition -->
                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="CATEGORY *" />
                        <ComboBox fx:id="fieldCategory" maxWidth="Infinity" promptText="Select category" styleClass="combo-box-base" />
                        <Label fx:id="msgCategory" styleClass="form-error" />
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="CONDITION *" />
                        <ComboBox fx:id="fieldCondition" maxWidth="Infinity" promptText="Select condition" styleClass="combo-box-base" />
                    </VBox>
                </HBox>

                <!-- Start Price + Reserve Price -->
                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label styleClass="form-label" text="STARTING PRICE ($)" />
                        <TextField fx:id="fieldStartPrice" promptText="0.00" styleClass="form-input" />
                        <Label fx:id="msgPrice" styleClass="form-error" />
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <!-- ── Right Column: Image + Schedule ─────────── -->
            <VBox maxWidth="320" minWidth="300" spacing="16">

                <!-- Image Upload -->
                <VBox spacing="14" styleClass="section-card">
                    <Label styleClass="section-title" text="Product Image" />
                    <!-- Preview area -->
                    <VBox fx:id="imagePreviewBox" alignment="CENTER" onMouseClicked="#handleImageUpload" spacing="8" style="-fx-background-color:#f8fafc; -fx-background-radius:10;                                  -fx-border-color:#e2e8f0; -fx-border-width:1.5;                                  -fx-border-radius:10; -fx-border-style:dashed;                                  -fx-pref-height:180; -fx-cursor:hand;">
                        <Label fx:id="imageIcon" style="-fx-font-size:36px; -fx-text-fill:#a0aec0;" text="📸" />
                        <Label fx:id="imageHint" style="-fx-font-size:12px; -fx-text-fill:#a0aec0;" text="Click to upload image" />
                        <Label style="-fx-font-size:10px; -fx-text-fill:#c4cdd8;" text="PNG, JPG up to 5MB" />
                    </VBox>
                    <Button maxWidth="Infinity" onAction="#handleImageUpload" styleClass="btn-secondary" text="Upload Image" />
                    <Label fx:id="msgImage" styleClass="form-error" />
                </VBox>

                <!-- Schedule -->
                <VBox spacing="14" styleClass="section-card">
                    <Label styleClass="section-title" text="Schedule" />

                    <VBox spacing="6">
                        <Label styleClass="form-label" text="START DATE &amp; TIME *" />
                        <TextField fx:id="fieldStartTime" promptText="YYYY-MM-DD HH:mm" styleClass="form-input" />
                        <Label styleClass="form-hint" text="Format: 2025-12-31 14:00" />
                    </VBox>

                    <VBox spacing="6">
                        <Label styleClass="form-label" text="END DATE &amp; TIME *" />
                        <TextField fx:id="fieldEndTime" promptText="YYYY-MM-DD HH:mm" styleClass="form-input" />
                        <Label fx:id="msgTime" styleClass="form-error" />
                    </VBox>

                    <!-- Duration shortcut buttons -->
                    <Label styleClass="form-label" text="QUICK DURATION" />
                    <HBox spacing="8">
                        <Button onAction="#set1Day" style="-fx-font-size:11px; -fx-padding:5 10;" styleClass="btn-secondary" text="1 Day" />
                        <Button onAction="#set3Days" style="-fx-font-size:11px; -fx-padding:5 10;" styleClass="btn-secondary" text="3 Days" />
                        <Button onAction="#set7Days" style="-fx-font-size:11px; -fx-padding:5 10;" styleClass="btn-secondary" text="7 Days" />
                    </HBox>
                </VBox>
            </VBox>
        </HBox>

        <!-- ── Submit bar ────────────────────────────────── -->
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="section-card">
            <Label fx:id="formMsg" styleClass="form-error" HBox.hgrow="ALWAYS" />
            <Button onAction="#saveDraft" styleClass="btn-secondary" text="Save as Draft" />
            <Button fx:id="submitBtn" onAction="#handleSubmit" styleClass="btn-primary" text="Publish Auction →" />
        </HBox>

        <Region minHeight="16" />
    </VBox>
</ScrollPane>
