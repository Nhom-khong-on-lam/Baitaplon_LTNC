<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" prefHeight="720.0" prefWidth="1200.0" stylesheets="@userHome.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.UserHomeController">
    <!-- BACKGROUND IMAGE -->
    <ImageView fitHeight="${root.height}" fitWidth="${root.width}" preserveRatio="false">
        <image>
            <Image url="@image/image6.jpg" />
        </image>
    </ImageView>

    <!-- DARK OVERLAY -->
    <Pane style="-fx-background-color: rgba(0,0,0,0.65);" />

    <!-- MAIN CONTENT (BorderPane) -->
    <BorderPane>
        <!-- TOP BAR -->
        <top>
            <HBox styleClass="top-bar" spacing="15.0" alignment="CENTER_LEFT">
                <Label styleClass="app-title" text="AUCTION USER PANEL" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="userNameLabel" styleClass="admin-name" />
                <Button onAction="#handleLogout" styleClass="logout-btn" text="LOGOUT" />
                <padding><Insets left="25" right="25" top="12" bottom="12" /></padding>
            </HBox>
        </top>

        <!-- LEFT SIDEBAR MENU -->
        <left>
            <VBox styleClass="sidebar" spacing="5.0">
                <padding><Insets top="20" left="10" right="10" bottom="20" /></padding>
                <Button onAction="#showDashboard" styleClass="menu-btn" text="📊 DASHBOARD" />
                <Button onAction="#showAuctions" styleClass="menu-btn" text="🔨 ACTIVE AUCTIONS" />
                <Button onAction="#showMyBids" styleClass="menu-btn" text="💰 MY BIDS" />
                <Button onAction="#showMyProducts" styleClass="menu-btn" text="📦 MY PRODUCTS" />
                <Button onAction="#showProfile" styleClass="menu-btn" text="👤 PROFILE" />
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#handleLogout" styleClass="menu-btn-danger" text="🚪 EXIT" />
            </VBox>
        </left>

        <!-- CENTER CONTENT (dynamic) -->
        <center>
            <StackPane fx:id="contentArea" styleClass="content-area" />
        </center>
    </BorderPane>
</StackPane>