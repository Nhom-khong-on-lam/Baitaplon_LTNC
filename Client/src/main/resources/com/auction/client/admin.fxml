<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
  admin.fxml — Admin Panel.
  Stat overview + tabs: Manage Users / Manage Auctions.
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.AdminController"
      spacing="16" styleClass="content-area">

    <!-- ── Header ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Admin Panel" styleClass="section-title"
               style="-fx-font-size:18px;" HBox.hgrow="ALWAYS"/>
        <Label fx:id="adminBadge"
               style="-fx-background-color:#fef3c7; -fx-text-fill:#92400e;
                      -fx-background-radius:20; -fx-font-size:11px;
                      -fx-font-weight:bold; -fx-padding:3 12;"
               text="⚙  Administrator Access"/>
    </HBox>

    <!-- ── Stat Cards ─────────────────────────────────────── -->
    <HBox spacing="14">
        <VBox styleClass="admin-stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <Label text="TOTAL USERS"    styleClass="stat-label"/>
            <Label fx:id="adminStatUsers"    styleClass="stat-value" text="0"/>
            <Label fx:id="adminStatUsersDelta" styleClass="stat-delta-up" text="↑ 12 this month"/>
        </VBox>
        <VBox styleClass="admin-stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <Label text="TOTAL AUCTIONS" styleClass="stat-label"/>
            <Label fx:id="adminStatAuctions" styleClass="stat-value" text="0"/>
            <Label styleClass="stat-delta-up" text="↑ 8 this week"/>
        </VBox>
        <VBox styleClass="admin-stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <Label text="ACTIVE NOW"     styleClass="stat-label"/>
            <Label fx:id="adminStatActive"   styleClass="stat-value"
                   style="-fx-text-fill:#16a34a;" text="0"/>
            <Label styleClass="stat-delta-up" text="🟢 live"/>
        </VBox>
        <VBox styleClass="admin-stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <Label text="TOTAL REVENUE"  styleClass="stat-label"/>
            <Label fx:id="adminStatRevenue"  styleClass="stat-value"
                   style="-fx-text-fill:#2563eb;" text="$0"/>
            <Label styleClass="stat-delta-up" text="↑ 15% vs last month"/>
        </VBox>
    </HBox>

    <!-- ── Tab buttons ────────────────────────────────────── -->
    <HBox spacing="8">
        <Button fx:id="tabUsers"    text="👥 Manage Users"
                styleClass="btn-primary"   onAction="#showUsers"/>
        <Button fx:id="tabAuctions" text="🔨 Manage Auctions"
                styleClass="btn-secondary" onAction="#showAuctions"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="adminSearch" styleClass="topbar-search"
                   promptText="Search..." onAction="#handleAdminSearch"/>
    </HBox>

    <!-- ── Users Table (default visible) ─────────────────── -->
    <VBox fx:id="usersPanel" styleClass="section-card" VBox.vgrow="ALWAYS" spacing="12">
        <Label text="All Users" styleClass="section-title"/>
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colUserId"     text="ID"       prefWidth="60"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colUserAvatar" text=""         prefWidth="50"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colUserName"   text="USERNAME" prefWidth="160"/>
                <TableColumn fx:id="colUserEmail"  text="EMAIL"    prefWidth="220"/>
                <TableColumn fx:id="colUserRole"   text="ROLE"     prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colUserStatus" text="STATUS"   prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colUserBids"   text="BIDS"     prefWidth="70"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colUserJoined" text="JOINED"   prefWidth="130"/>
                <TableColumn fx:id="colUserAction" text="ACTIONS"  prefWidth="150" style="-fx-alignment:CENTER;"/>
            </columns>
            <placeholder>
                <Label text="No users found."
                       style="-fx-text-fill:#a0aec0;"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- ── Auctions Table (hidden initially) ─────────────── -->
    <VBox fx:id="auctionsPanel" styleClass="section-card" VBox.vgrow="ALWAYS"
          spacing="12" visible="false" managed="false">
        <Label text="All Auctions" styleClass="section-title"/>
        <TableView fx:id="auctionsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colAucId"      text="ID"      prefWidth="60"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colAucTitle"   text="TITLE"   prefWidth="200"/>
                <TableColumn fx:id="colAucSeller"  text="SELLER"  prefWidth="130"/>
                <TableColumn fx:id="colAucCat"     text="CATEGORY" prefWidth="120" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colAucPrice"   text="CURRENT BID" prefWidth="120" style="-fx-alignment:CENTER_RIGHT;"/>
                <TableColumn fx:id="colAucBids"    text="BIDS"    prefWidth="70"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colAucStatus"  text="STATUS"  prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colAucEnds"    text="ENDS"    prefWidth="130"/>
                <TableColumn fx:id="colAucAction"  text="ACTIONS" prefWidth="120" style="-fx-alignment:CENTER;"/>
            </columns>
            <placeholder>
                <Label text="No auctions found."
                       style="-fx-text-fill:#a0aec0;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
