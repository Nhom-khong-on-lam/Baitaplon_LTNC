<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  dashboard.fxml — Màn hình tổng quan chính.
  Load động vào contentPane của MainController.
-->

<ScrollPane fitToHeight="false" fitToWidth="true" styleClass="scroll-pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.DashboardController">
    <stylesheets>
        <URL value="@global.css" />
    </stylesheets>

    <VBox spacing="20" styleClass="content-area">

        <!-- ── Welcome Card ─────────────────────────────────── -->
        <HBox alignment="CENTER_LEFT" spacing="0" styleClass="welcome-card">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label fx:id="welcomeGreeting" styleClass="welcome-greeting" text="Good morning, User 👋" />
                <Label fx:id="welcomeSub" styleClass="welcome-sub" text="Here's what's happening in the auction world today." />
                <HBox spacing="10" style="-fx-padding:12 0 0 0;">
                    <Button onAction="#goToAuctions" styleClass="welcome-quick-btn" text="Browse Auctions" />
                    <Button onAction="#goToCreate" styleClass="welcome-quick-btn-ghost" text="+ Create Auction" />
                </HBox>
            </VBox>
            <VBox alignment="CENTER_RIGHT" spacing="6">
                <Label fx:id="welcomeBadge" styleClass="welcome-badge" text="🟢  LIVE NOW — 12 Auctions" />
                <Label fx:id="welcomeDate" style="-fx-text-fill:#2a4060; -fx-font-size:11px;" text="Saturday, May 09" />
            </VBox>
        </HBox>

        <!-- ── Stat Cards ────────────────────────────────────── -->
        <HBox spacing="16">
            <!-- Active Auctions -->
            <VBox prefHeight="91.0" prefWidth="176.0" spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="ACTIVE AUCTIONS" />
                        <Label fx:id="statActiveAuctions" styleClass="stat-value" text="0" />
                    </VBox>
                    <Label fx:id="statAuctionDelta" styleClass="stat-delta-up" text="↑ 3" />
                </HBox>
            </VBox>
            <!-- My Bids -->
            <VBox prefHeight="91.0" prefWidth="150.0" spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="MY BIDS" />
                        <Label fx:id="statMyBids" styleClass="stat-value" text="0" />
                    </VBox>
                    <Label fx:id="statBidDelta" styleClass="stat-delta-up" text="↑ 1" />
                </HBox>
            </VBox>
            <!-- Winning -->
            <VBox prefHeight="91.0" prefWidth="147.0" spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="WINNING" />
                        <Label fx:id="statWinning" styleClass="stat-value" text="0" />
                    </VBox>
                    <Label styleClass="stat-delta-up" text="↑ 2" />
                </HBox>
            </VBox>
            <!-- My Products -->
            <VBox prefHeight="91.0" prefWidth="175.0" spacing="12" styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="MY PRODUCTS" />
                        <Label fx:id="statMyProducts" styleClass="stat-value" text="0" />
                    </VBox>
                    <Label styleClass="stat-delta-up" text="↑ 5" />
                </HBox>
            </VBox>
        </HBox>

        <!-- ── Bottom: Live Auctions + Activity ─────────────── -->
        <HBox spacing="16">

            <!-- Live Auctions Section -->
            <VBox spacing="14" styleClass="section-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="section-title" text="Live Auctions" />
                        <Label styleClass="section-subtitle" text="Ending soon — don't miss out" />
                    </VBox>
                    <Button onAction="#goToAuctions" styleClass="section-link-btn" text="View All →" />
                </HBox>

                <!-- Auction rows injected by controller -->
                <VBox fx:id="liveAuctionList" spacing="10" />
            </VBox>

            <!-- Recent Activity -->
            <VBox maxWidth="300" minWidth="280" spacing="14" styleClass="section-card">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="section-title" text="Recent Activity" HBox.hgrow="ALWAYS" />
                </HBox>
                <VBox fx:id="activityList" spacing="12" />
            </VBox>

        </HBox>

        <!-- Bottom padding -->
        <Region minHeight="16" />
    </VBox>
</ScrollPane>
