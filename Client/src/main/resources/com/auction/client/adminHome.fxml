<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" prefHeight="720.0" prefWidth="1200.0" stylesheets="@adminHome.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminHomeController">
    <!-- BACKGROUND IMAGE -->
    <ImageView fitHeight="${root.height}" fitWidth="${root.width}" preserveRatio="false">
        <image>
            <Image url="@image/image3.jpg" />
        </image>
    </ImageView>

    <!-- DARK OVERLAY -->
    <Pane style="-fx-background-color: rgba(0,0,0,0.65);" />

    <!-- MAIN CONTENT (BorderPane) -->
    <BorderPane>
        <!-- TOP BAR -->
        <top>
            <HBox styleClass="top-bar" spacing="15.0" alignment="CENTER_LEFT">
                <Label styleClass="app-title" text="AUCTION ADMIN PANEL" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="adminNameLabel" styleClass="admin-name" />
                <Button onAction="#handleLogout" styleClass="logout-btn" text="LOGOUT" />
                <padding><Insets left="25" right="25" top="12" bottom="12" /></padding>
            </HBox>
        </top>

        <!-- LEFT SIDEBAR MENU -->
        <left>
            <VBox styleClass="sidebar" spacing="5.0">
                <padding><Insets top="20" left="10" right="10" bottom="20" /></padding>
                <Button onAction="#showDashboard" styleClass="menu-btn" text="📊 DASHBOARD" />
                <Button onAction="#showUserManagement" styleClass="menu-btn" text="👥 USER MANAGEMENT" />
                <Button onAction="#showProductManagement" styleClass="menu-btn" text="🏷️ PRODUCT MANAGEMENT" />
                <Button onAction="#showAuctionManagement" styleClass="menu-btn" text="⏱️ AUCTION SESSIONS" />
                <Button onAction="#showReports" styleClass="menu-btn" text="📈 REPORTS" />
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#handleLogout" styleClass="menu-btn-danger" text="🚪 EXIT" />
            </VBox>
        </left>

        <!-- CENTER CONTENT (dynamic) -->
        <center>
            <StackPane fx:id="contentArea" styleClass="content-area" />
        </center>
    </BorderPane>
</StackPane>