<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.LoginController"
      styleClass="auth-root"
      prefWidth="1100" prefHeight="700">

    <!-- ══ LEFT PANEL — Dark brand panel ══════════════════ -->
    <VBox styleClass="auth-left" alignment="CENTER" spacing="0">
        <padding><Insets top="60" right="52" bottom="60" left="52"/></padding>

        <!-- Brand -->
        <VBox spacing="4" VBox.vgrow="NEVER">
            <Label text="AURUM" styleClass="auth-brand"/>
            <Label text="AUCTION PLATFORM" styleClass="auth-brand-sub"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS" minHeight="40"/>

        <!-- Headline -->
        <VBox spacing="12" maxWidth="300">
            <Label text="The Premier&#10;Auction Experience."
                   styleClass="auth-headline"/>
            <Label text="Bid on exclusive items from verified sellers worldwide. Real-time auctions, secure transactions."
                   styleClass="auth-headline-sub"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS" minHeight="40"/>

        <!-- Feature list -->
        <VBox spacing="14">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="⚡" styleClass="auth-feature-icon"/>
                <Label text="Real-time bidding with live countdown" styleClass="auth-feature-text"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="🔒" styleClass="auth-feature-icon"/>
                <Label text="Secure OTP-verified transactions" styleClass="auth-feature-text"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="📊" styleClass="auth-feature-icon"/>
                <Label text="Detailed analytics dashboard" styleClass="auth-feature-text"/>
            </HBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS" minHeight="30"/>

        <Label text="© 2025 AURUM Inc." style="-fx-text-fill:#1e3050; -fx-font-size:10px;"/>
    </VBox>

    <!-- ══ RIGHT PANEL — Form ════════════════════════════ -->
    <VBox fx:id="formPanel" styleClass="auth-right" alignment="CENTER"
          HBox.hgrow="ALWAYS">

        <VBox maxWidth="360" spacing="0">

            <!-- Header -->
            <Label text="Welcome back" styleClass="auth-form-title"/>
            <Label text="Sign in to your account to continue"
                   styleClass="auth-form-sub"
                   style="-fx-padding:6 0 32 0;"/>

            <!-- Username -->
            <VBox spacing="6" style="-fx-padding:0 0 16 0;">
                <Label text="USERNAME" styleClass="auth-field-label"/>
                <TextField fx:id="loginUser" styleClass="auth-input"
                           promptText="Enter your username"
                           maxWidth="Infinity"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6" style="-fx-padding:0 0 6 0;">
                <Label text="PASSWORD" styleClass="auth-field-label"/>
                <PasswordField fx:id="loginPass" styleClass="auth-input"
                               promptText="Enter your password"
                               maxWidth="Infinity"/>
            </VBox>

            <!-- Remember + Forgot -->
            <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding:0 0 20 0;">
                <CheckBox fx:id="rememberCheck" text="Remember me"
                          styleClass="remember-check"
                          style="-fx-text-fill:#4a5568; -fx-font-size:12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Forgot password?" styleClass="auth-link"
                        onAction="#handleForgotPassword"/>
            </HBox>

            <!-- Message -->
            <Label fx:id="loginMsg" styleClass="auth-msg"
                   style="-fx-padding:0 0 12 0;" maxWidth="360"
                   wrapText="true"/>

            <!-- Login Button -->
            <Button fx:id="loginBtn" text="Sign In"
                    styleClass="auth-btn-primary"
                    onAction="#handleLogin"
                    maxWidth="Infinity"/>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="0" style="-fx-padding:22 0 22 0;">
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-border-color:#e2e8f0; -fx-border-width:1 0 0 0; -fx-pref-height:1;"/>
                <Label text="or" styleClass="auth-divider-label"/>
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-border-color:#e2e8f0; -fx-border-width:1 0 0 0; -fx-pref-height:1;"/>
            </HBox>

            <!-- Switch to Register -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?"
                       style="-fx-text-fill:#718096; -fx-font-size:12px;"/>
                <Button text="Create one →" styleClass="auth-link"
                        onAction="#goToRegister"/>
            </HBox>

        </VBox>
    </VBox>

</HBox>
