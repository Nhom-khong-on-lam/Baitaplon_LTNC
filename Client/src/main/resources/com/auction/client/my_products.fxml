<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
  my_products.fxml — Quản lý sản phẩm / phiên đấu giá của người bán.
-->
<?import java.lang.String?>
<?import java.net.URL?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.MyProductsController"
      spacing="16" styleClass="content-area">
    <stylesheets>
        <URL value="@global.css"/>
    </stylesheets>
    <!-- ── Header ───────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="My Products" styleClass="section-title"
                   style="-fx-font-size:18px;"/>
            <Label text="Manage your auction listings." styleClass="section-subtitle"/>
        </VBox>
        <Button text="+ Create Auction" styleClass="btn-primary"
                onAction="#goToCreate"/>
    </HBox>

    <!-- ── Status filter tabs ───────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button fx:id="tabAll"      text="All"        styleClass="btn-primary"  onAction="#showAll"/>
        <Button fx:id="tabLive"     text="🟢 Live"    styleClass="btn-secondary" onAction="#showLive"/>
        <Button fx:id="tabPending"  text="🕐 Pending" styleClass="btn-secondary" onAction="#showPending"/>
        <Button fx:id="tabFinished" text="✅ Finished" styleClass="btn-secondary" onAction="#showFinished"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="productCount" styleClass="section-subtitle" text="0 products"/>
    </HBox>

    <!-- ── Product Table ────────────────────────────────────── -->
    <VBox styleClass="section-card" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="productTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colTitle"    text="PRODUCT"    prefWidth="200"/>
                <TableColumn fx:id="colCategory" text="CATEGORY"   prefWidth="120" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colStart"    text="START PRICE" prefWidth="120" style="-fx-alignment:CENTER_RIGHT;"/>
                <TableColumn fx:id="colCurrent"  text="CURRENT BID" prefWidth="130" style="-fx-alignment:CENTER_RIGHT;"/>
                <TableColumn fx:id="colBids"     text="BIDS"        prefWidth="70"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colStatus"   text="STATUS"      prefWidth="130" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colEnds"     text="ENDS"        prefWidth="130"/>
                <TableColumn fx:id="colAction"   text="ACTION"      prefWidth="150" style="-fx-alignment:CENTER;"/>
            </columns>
            <placeholder>
                <Label text="No products found. Start by creating an auction!"
                       style="-fx-text-fill:#a0aec0; -fx-font-size:13px;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
