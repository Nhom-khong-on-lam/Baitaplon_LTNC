<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" prefHeight="650.0" prefWidth="900.0" stylesheets="@auth.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.client.controller.AuthController">
    <children>
        <ImageView fitHeight="${root.height}" fitWidth="${root.width}" preserveRatio="false" pickOnBounds="true">
            <image>
                <Image url="@image/image2.jpg" />
            </image>
        </ImageView>

        <Pane style="-fx-background-color: rgba(0,0,0,0.6);" />

        <StackPane fx:id="formContainer" maxWidth="400.0" maxHeight="580.0">
            <children>

                <VBox fx:id="loginForm" alignment="CENTER" spacing="20.0" styleClass="auth-card">
                    <children>
                        <Label styleClass="header-label" text="AUCTION SYSTEM" />
                        <Label fx:id="loginMsg" styleClass="message-label" />
                        <VBox spacing="12.0">
                            <TextField fx:id="loginUser" promptText="Username or Email" styleClass="custom-input" />
                            <PasswordField fx:id="loginPass" promptText="Password" styleClass="custom-input" />
                        </VBox>
                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Hyperlink onAction="#showForgotForm" styleClass="switch-link" text="Forgot Password?" />
                            </children>
                        </HBox>
                        <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="primary-button" text="LOGIN" />
                        <Hyperlink onAction="#showRegisterForm" styleClass="switch-link" text="Don't have an account? Create one" />
                    </children>
                    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
                </VBox>

                <VBox fx:id="registerForm" alignment="CENTER" opacity="0.0" spacing="15.0" styleClass="auth-card" visible="false">
                    <children>
                        <Label styleClass="header-label" text="REGISTER" />
                        <Label fx:id="regMsg" styleClass="message-label" />
                        <VBox spacing="10.0">
                            <TextField fx:id="regUser" promptText="Username" styleClass="custom-input" />
                            <HBox spacing="5.0">
                                <children>
                                    <TextField fx:id="regEmail" promptText="Email Address" styleClass="custom-input" HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleSendOTP" styleClass="primary-button" text="Send OTP" />
                                </children>
                            </HBox>
                            <TextField fx:id="otpInput" promptText="Enter 6-digit OTP" styleClass="custom-input" />
                            <PasswordField fx:id="regPass" promptText="Password" styleClass="custom-input" />
                            <PasswordField fx:id="regConfirmPass" promptText="Confirm Password" styleClass="custom-input" />
                        </VBox>
                        <Button maxWidth="Infinity" onAction="#handleRegister" styleClass="primary-button" text="SIGN UP" />
                        <Hyperlink onAction="#showLoginForm" styleClass="switch-link" text="Already have an account? Back to Login" />
                    </children>
                    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
                </VBox>

                <VBox fx:id="forgotForm" alignment="CENTER" opacity="0.0" spacing="12.0" styleClass="auth-card" visible="false">
                    <children>
                        <Label styleClass="header-label" text="FORGOT PASSWORD" />
                        <Label fx:id="forgotMsg" styleClass="message-label" wrapText="true" />

                        <VBox spacing="8.0">
                            <HBox spacing="5.0">
                                <children>
                                    <TextField fx:id="forgotEmail" promptText="Enter registered email" styleClass="custom-input" HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleSendForgotOTP" styleClass="primary-button" text="Send OTP" />
                                </children>
                            </HBox>
                            <TextField fx:id="forgotOtpInput" promptText="Enter 6-digit OTP" styleClass="custom-input" />
                            <PasswordField fx:id="newPass" promptText="New Password" styleClass="custom-input" />
                            <PasswordField fx:id="confirmNewPass" promptText="Confirm New Password" styleClass="custom-input" />
                        </VBox>

                        <Button maxWidth="Infinity" onAction="#handleResetPassword" styleClass="primary-button" text="RESET PASSWORD" />
                        <Hyperlink onAction="#showLoginForm" styleClass="switch-link" text="Back to Login" />
                    </children>
                    <padding>
                        <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
                    </padding>
                </VBox>

            </children>
        </StackPane>
    </children>
</StackPane>