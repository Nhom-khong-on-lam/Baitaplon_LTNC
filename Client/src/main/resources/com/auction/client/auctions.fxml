<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  auctions.fxml — Danh sách đấu giá live.
  Có search bar, filter, sort, và card list.
-->

<VBox spacing="0" styleClass="content-area" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionsController">
    <stylesheets>
        <URL value="@global.css" />
    </stylesheets>

    <!-- ── Status Tabs: All / Live / Ended ──────────────────── -->
    <HBox fx:id="tabBar" alignment="CENTER_LEFT" spacing="0" style="-fx-padding:0 0 16 0;">
        <Button fx:id="tabAll" onAction="#switchTabAll" styleClass="tab-btn,tab-btn-active" text="All" />
        <Button fx:id="tabLive" onAction="#switchTabLive" styleClass="tab-btn" text="🟢 Live" />
        <Button fx:id="tabEnded" onAction="#switchTabEnded" styleClass="tab-btn" text="🏁 Ended" />
    </HBox>

    <!-- ── Toolbar: Search + Filter + Sort ──────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding:0 0 18 0;">

        <!-- Search -->
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding:8 14; -fx-background-radius:10;" styleClass="section-card" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size:14px; -fx-text-fill:#a0aec0;" text="🔍" />
            <TextField fx:id="searchField" onAction="#handleSearch" promptText="Search auctions..." style="-fx-background-color:transparent; -fx-border-width:0;" HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Category filter -->
        <ComboBox fx:id="categoryFilter" onAction="#handleFilter" prefWidth="160" promptText="All Categories" styleClass="combo-box-base" />

        <!-- Sort -->
        <ComboBox fx:id="sortBox" onAction="#handleSort" prefWidth="140" promptText="Sort By" styleClass="combo-box-base" />

        <!-- Clear -->
        <Button onAction="#clearFilters" styleClass="btn-secondary" text="Clear" />
    </HBox>

    <!-- ── Results count ─────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" style="-fx-padding:0 0 12 0;">
        <Label fx:id="resultCount" styleClass="section-subtitle" text="Showing 0 auctions" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="listViewBtn" onAction="#switchToList" style="-fx-padding:6 10; -fx-margin:0 0 0 6;" styleClass="btn-primary" text="☰" />
    </HBox>

    <!-- ── Auction Cards List (scroll) ──────────────────────── -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <VBox fx:id="auctionListContainer" spacing="12" style="-fx-padding:0 0 24 0;" />
    </ScrollPane>

</VBox>
