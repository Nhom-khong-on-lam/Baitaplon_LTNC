<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  main.fxml — App shell dành cho USER (phiên bản UI mới).
  Controller: MainController (giữ nguyên toàn bộ logic).
  Admin có shell riêng: admin_main.fxml / AdminMainController.
-->

<HBox fx:id="mainRoot" prefHeight="700" prefWidth="1100" styleClass="main-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainController">
    <stylesheets>
        <URL value="@global.css" />
    </stylesheets>

    <!-- ══ SIDEBAR ════════════════════════════════════════════ -->
    <VBox fx:id="sidebar" spacing="0" styleClass="sidebar">

        <!-- Logo / Brand -->
        <VBox alignment="CENTER_LEFT" spacing="3" styleClass="sidebar-logo-area">
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label styleClass="sidebar-logo" text="AURUM" />
                <Label styleClass="sidebar-logo-dot" text="." />
            </HBox>
            <Label styleClass="sidebar-tagline" text="AUCTION PLATFORM" />
        </VBox>

        <!-- User info card -->
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-user-area">
            <Label fx:id="sidebarAvatar" styleClass="sidebar-avatar" text="AU" />
            <VBox spacing="2">
                <Label fx:id="sidebarUserName" styleClass="sidebar-user-name" text="Username" />
                <Label fx:id="sidebarUserRole" styleClass="sidebar-user-role" text="Member" />
            </VBox>
        </HBox>

        <!-- Section: MAIN -->
        <Label styleClass="sidebar-section" text="MAIN" />

        <Button fx:id="navDashboard" maxWidth="Infinity" onAction="#navDashboard" styleClass="nav-btn">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="nav-icon" text="⬛" />
                    <Label styleClass="nav-label" text="Dashboard" />
                </HBox>
            </graphic>
        </Button>

        <Button fx:id="navAuctions" maxWidth="Infinity" onAction="#navAuctions" styleClass="nav-btn">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="nav-icon" text="🔨" />
                    <Label styleClass="nav-label" text="Live Auctions" />
                </HBox>
            </graphic>
        </Button>

        <Button fx:id="navMyBids" maxWidth="Infinity" onAction="#navMyBids" styleClass="nav-btn">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="nav-icon" text="💰" />
                    <Label styleClass="nav-label" text="My Bids" />
                </HBox>
            </graphic>
        </Button>

        <Button fx:id="navMyProducts" maxWidth="Infinity" onAction="#navMyProducts" styleClass="nav-btn">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="nav-icon" text="📦" />
                    <Label styleClass="nav-label" text="My Products" />
                </HBox>
            </graphic>
        </Button>

        <Button fx:id="navCreate" maxWidth="Infinity" onAction="#navCreate" styleClass="nav-btn">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="nav-icon" text="➕" />
                    <Label styleClass="nav-label" text="Create Auction" />
                </HBox>
            </graphic>
        </Button>

        <!-- Section: ACCOUNT -->
        <Label styleClass="sidebar-section" text="ACCOUNT" />

        <Button fx:id="navProfile" maxWidth="Infinity" onAction="#navProfile" styleClass="nav-btn">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="nav-icon" text="👤" />
                    <Label styleClass="nav-label" text="Profile" />
                </HBox>
            </graphic>
        </Button>

        <!-- Spacer đẩy logout xuống cuối -->
        <Region VBox.vgrow="ALWAYS" />

        <!-- Logout -->
        <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="nav-btn-logout">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="nav-icon" text="🚪" />
                    <Label styleClass="nav-label" text="Sign Out" />
                </HBox>
            </graphic>
        </Button>

    </VBox>

    <!-- ══ RIGHT SIDE ══════════════════════════════════════════ -->
    <VBox HBox.hgrow="ALWAYS">

        <!-- Topbar -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">

            <!-- Title + breadcrumb -->
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="topbarTitle" styleClass="topbar-page-title" text="Dashboard" />
                <Label fx:id="topbarBread" styleClass="topbar-breadcrumb" text="Home / Dashboard" />
            </VBox>

            <!-- Search -->
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="topbar-search-wrap">
                <Label styleClass="search-icon" text="🔍" />
                <TextField fx:id="topbarSearch" onAction="#handleSearch" promptText="Search auctions…" styleClass="topbar-search" />
            </HBox>

            <!-- Notifications -->
            <Button onAction="#handleNotifications" styleClass="topbar-icon-btn" text="🔔" />

            <!-- Avatar -->
            <Label fx:id="topbarAvatar" onMouseClicked="#handleAvatarClick" styleClass="topbar-avatar-btn" text="  AU" />

        </HBox>

        <!-- Dynamic content pane -->
        <StackPane fx:id="contentPane" styleClass="content-area" VBox.vgrow="ALWAYS" />

    </VBox>

</HBox>
