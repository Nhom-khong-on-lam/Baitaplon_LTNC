<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<!--
  admin_auctions.fxml — Quản lý toàn bộ phiên đấu giá.
  Có filter theo status, search, và action buttons.
-->
<?import java.net.URL?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.AdminAuctionsController"
      spacing="16" styleClass="content-area">
    <stylesheets>
        <URL value="@global.css"/>
    </stylesheets>

    <!-- ── Header ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="Manage Auctions" styleClass="section-title"
                   style="-fx-font-size:18px;"/>
            <Label text="Monitor, end early, or remove auction listings."
                   styleClass="section-subtitle"/>
        </VBox>
        <Label fx:id="totalLabel" styleClass="section-subtitle" text="0 auctions"/>
    </HBox>

    <!-- ── Filter tabs + Search ───────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">

        <Button fx:id="tabAll"      text="All"          styleClass="btn-primary"
                onAction="#showAll"/>
        <Button fx:id="tabLive"     text="Live"     styleClass="btn-secondary"
                onAction="#showLive"/>
        <Button fx:id="tabEnding"   text="Ending"   styleClass="btn-secondary"
                onAction="#showEnding"/>
        <Button fx:id="tabFinished" text="Finished" styleClass="btn-secondary"
                onAction="#showFinished"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Search -->
        <HBox styleClass="section-card" spacing="0" alignment="CENTER_LEFT"
              style="-fx-padding:6 12; -fx-background-radius:8;">
            <Label text="🔍" style="-fx-font-size:13px; -fx-text-fill:#a0aec0;"/>
            <TextField fx:id="searchField" promptText="Search by title or seller..."
                       style="-fx-background-color:transparent; -fx-border-width:0;"
                       prefWidth="220" onAction="#handleSearch"/>
        </HBox>
        <Button text="Search" styleClass="btn-primary" onAction="#handleSearch"/>
    </HBox>

    <!-- ── Auctions Table ─────────────────────────────────── -->
    <VBox styleClass="section-card" VBox.vgrow="ALWAYS" spacing="0">
        <TableView fx:id="auctionsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId"      text="ID"
                             prefWidth="80"
                             style="-fx-alignment:CENTER;"/>

                <TableColumn fx:id="colTitle"   text="TITLE"
                             prefWidth="150"/>
                <TableColumn fx:id="colSeller"  text="SELLER"
                             prefWidth="200"/>
                <TableColumn fx:id="colCat"     text="CATEGORY"
                             prefWidth="120"
                             style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colPrice"   text="CURRENT BID"
                             prefWidth="130"
                             style="-fx-alignment:CENTER_RIGHT;"/>
                <TableColumn fx:id="colBids"    text="BIDS"
                             prefWidth="65"
                             style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colStatus"  text="STATUS"
                             prefWidth="105"
                             style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colEnds"    text="ENDS"
                             prefWidth="120"/>
                <TableColumn fx:id="colActions" text="ACTIONS"
                             prefWidth="250"
                             style="-fx-alignment:CENTER;"/>
            </columns>
            <placeholder>
                <Label text="No auctions found."
                       style="-fx-text-fill:#a0aec0; -fx-font-size:13px;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
